# =============================================
# THEVIRALRECIPE.COM — Variabili d'ambiente
# Copia questo file in .env.local e compila i valori
# MAI committare .env.local su Git!
# =============================================

# ── SUPABASE ──────────────────────────────────
# Trovale su: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tuo-progetto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service Role Key — SOLO per admin/pipeline, MAI esposta al client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── STRIPE ────────────────────────────────────
# Trovale su: Stripe Dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Crea i prodotti su Stripe e copia qui i Price ID
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_CREATOR_PRO_PRICE_ID=price_...
# Webhook secret — Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── CLAUDE API (per pipeline AI) ──────────────
# Trovale su: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── REPLICATE (per generazione immagini AI) ───
# Trovale su: replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# ── EDAMAM (valori nutrizionali) ─────────────
# Registrati su: developer.edamam.com
EDAMAM_APP_ID=...
EDAMAM_APP_KEY=...

# ── YOUTUBE DATA API ──────────────────────────
# Google Cloud Console > APIs > YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# ── TIKTOK (Research API) ─────────────────────
# developers.tiktok.com (richiede approvazione)
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...

# ── SICUREZZA ─────────────────────────────────
# Stringa random — usata per firmare i token Cron (genera con: openssl rand -hex 32)
CRON_SECRET=cambia-questa-stringa-con-qualcosa-di-random

# ── URL SITO ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://theviralrecipe.com
# In sviluppo:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── SUPABASE PROJECT ID ───────────────────────
# Usato per generare i tipi TypeScript (npm run supabase:types)
SUPABASE_PROJECT_ID=tuo-project-id
